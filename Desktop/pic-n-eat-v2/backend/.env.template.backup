# Pic N Eat Environment Variables
# Copy this file to .env and fill in your values

# ============== Application ==============
APP_NAME=Pic N Eat API
VERSION=2.0.0
DEBUG=False  # Set to True for development
API_V1_PREFIX=/api/v1

# ============== Security ==============
# Generate a secure secret key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============== Database ==============
# For local development with Docker Compose:
DATABASE_URL=postgresql://postgres:postgres@db:5432/picneat

# For production (Railway, Render, etc.):
# DATABASE_URL=postgresql://username:password@host:5432/database

# ============== AWS S3 Storage ==============
# Get AWS credentials from https://console.aws.amazon.com/iam/
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=picneat-images
S3_UPLOAD_PREFIX=uploads

# ============== USDA Food Data Central API ==============
# Get your API key from https://fdc.nal.usda.gov/api-key-signup.html
USDA_FDC_API_KEY=your-usda-fdc-api-key
FDC_API_BASE_URL=https://api.nal.usda.gov/fdc/v1

# ============== ML Model ==============
MODEL_PATH=./models/best_model.pth
USE_ONNX=True
MODEL_DEVICE=cpu  # Use "cuda" if GPU available

# ============== CORS ==============
# Add your frontend URLs here (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ============== Gamification ==============
POINTS_PER_MEAL_LOGGED=10
POINTS_PER_RESISTANCE=25
RESISTANCE_STREAK_MULTIPLIER=1.5

# ============== File Upload ==============
MAX_UPLOAD_SIZE_MB=10
