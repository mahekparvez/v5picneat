# =================================
# Pic N Eat V2 Environment Configuration
# =================================

# Application Settings
APP_NAME=Pic N Eat V2
APP_VERSION=2.0.0
DEBUG=true
ENVIRONMENT=development  # development, staging, production

# API Configuration
API_V1_STR=/api/v1
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Configuration
# Local PostgreSQL:
DATABASE_URL=postgresql://postgres:password@localhost:5432/pic_n_eat_v2

# Production (Railway/Render/AWS RDS):
# DATABASE_URL=postgresql://user:password@host:5432/database

DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# S3 / CloudFlare R2 Storage
S3_BUCKET_NAME=pic-n-eat-production
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# For CloudFlare R2, add endpoint URL:
# S3_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com

# USDA FoodData Central API
# Get your key from: https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=your-usda-api-key-here
USDA_API_URL=https://api.nal.usda.gov/fdc/v1
USDA_RATE_LIMIT=1000

# ML Model Configuration
MODEL_PATH=./models/food_classifier.pth
MODEL_DEVICE=cpu  # cpu or cuda
MODEL_BATCH_SIZE=32
CONFIDENCE_THRESHOLD=0.7

# Image Processing
MAX_IMAGE_SIZE_MB=10
THUMBNAIL_SIZE=(200, 200)

# Gamification Settings
RESISTANCE_BASE_POINTS=10
HIGH_CALORIE_THRESHOLD=500
HIGH_CALORIE_BONUS=5
LATE_NIGHT_HOUR=22
LATE_NIGHT_BONUS=3

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# CORS Settings (Frontend URLs)
BACKEND_CORS_ORIGINS=["http://localhost:3000", "https://your-frontend-domain.com"]

# Monitoring (Optional)
ENABLE_METRICS=true
SENTRY_DSN=  # Optional: Add Sentry for error tracking
